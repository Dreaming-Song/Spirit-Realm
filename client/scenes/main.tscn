[gd_scene load_steps=3 format=3 uid="uid://main_scene"]

[ext_resource type="Script" path="res://scripts/player/player.gd" id="1"]
[ext_resource type="Script" path="res://scripts/ui/hud.gd" id="2"]

[node name="Main" type="Node3D"]

# ===== 场景世界 =====
[node name="World" type="Node3D" parent="."]
node_group = "world"

[node name="DirectionalLight" type="DirectionalLight3D" parent="World"]
