; 灵境 - Godot 4.x 项目配置
; Phase 1: 基础搭建

[application]
config/name="灵境"
config/description="仙侠风格·旷野之息式·洛克王国式灵宠·2-4人联机开放世界"
run/main_scene="res://scenes/main.tscn"
config/icon="res://assets/textures/icon.png"

[autoload]
MagicSystem="*res://scripts/magic/magic_system.gd"
AlchemySystem="*res://scripts/alchemy/alchemy_system.gd"
SaveSystem="*res://scripts/save/save_system.gd"
NetworkManager="*res://scripts/network/network_manager.gd"
QuestSystem="*res://scripts/quest/quest_system.gd"
CultivationSchool="*res://scripts/combat/cultivation_school.gd"
CultivationSystem="*res://scripts/combat/cultivation_system.gd"
SkillManager="*res://scripts/combat/skill_manager.gd"
DamageCalculator="*res://scripts/combat/damage_calculator.gd"
BuffSystem="*res://scripts/combat/buff_system.gd"

[rendering]
renderer/rendering_method="mobile"
environment/defaults/default_clear_color=Color(0.5, 0.7, 1.0, 1.0)

[input]
; 基础移动
move_forward={
"deadzone": 0.5,
"events": [{"keycode": 87, "type": 0}]
}
move_back={
"deadzone": 0.5,
"events": [{"keycode": 83, "type": 0}]
}
move_left={
"deadzone": 0.5,
"events": [{"keycode": 65, "type": 0}]
}
move_right={
"deadzone": 0.5,
"events": [{"keycode": 68, "type": 0}]
}
; 跳跃/御剑
jump={
"deadzone": 0.5,
"events": [{"keycode": 32, "type": 0}]
}
sword_fly={
"deadzone": 0.5,
"events": [{"keycode": 70, "type": 0}]
}
; 交互
interact={
"deadzone": 0.5,
"events": [{"keycode": 69, "type": 0}]
}
attack={
"deadzone": 0.5,
"events": [{"keycode": 4194325, "type": 0}]
}

[physics]
common/physics_ticks_per_second=60
3d/default_gravity=-24.5
